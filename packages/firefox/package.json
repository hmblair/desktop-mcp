{
  "name": "firefox-mcp",
  "version": "2.3.0",
  "description": "MCP server for Firefox - enables AI assistants to control the browser",
  "author": "Hamish Blair",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmblair/firefox-mcp"
  },
  "main": "./server/dist/index.js",
  "bin": {
    "firefox-mcp": "./server/dist/native-host.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:server": "esbuild server/native-host.ts --bundle --platform=node --outfile=server/dist/native-host.js --format=cjs --external:@modelcontextprotocol/sdk --external:dayjs --external:zod && esbuild server/index.ts --bundle --platform=node --outfile=server/dist/index.js --format=cjs --external:@modelcontextprotocol/sdk --external:dayjs --external:zod",
    "build:extension": "esbuild extension/background.ts --bundle --outfile=extension/dist/background.js",
    "typecheck": "tsc --noEmit -p extension/tsconfig.json",
    "build": "npm run typecheck && npm run build:server && npm run build:extension",
    "test": "node test/smoke.cjs"
  },
  "dependencies": {
    "@desktop-mcp/shared": "*",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "dayjs": "^1.11.13",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "esbuild": "0.25.1",
    "typescript": "^5.8.2"
  }
}
